{
	"editor.codeActionsOnSave": {
		"source.fixAll": "explicit",
		"source.organizeImports": "explicit",
		"source.sortMembers": "explicit"
	},
	"editor.tabSize": 4,
	"editor.insertSpaces": true,
	"editor.detectIndentation": false,
	"[javascript]": {
		"editor.tabSize": 4
	},
	"[typescript]": {
		"editor.tabSize": 4
	},
	"[json]": {
		"editor.tabSize": 4
	},
	"[jsonc]": {
		"editor.tabSize": 4
	}
}
